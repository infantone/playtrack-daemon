# =============================================================================
# PlayTrack — file di configurazione di esempio
#
# Copia questo file in /opt/playtrack/.env sul Raspberry e riempi i valori.
#   - Le righe con "DIVERSO" cambiano su ogni RPi
#   - Le righe con "UGUALE"  sono identiche su tutti i RPi del progetto
#
# Regole: nessuna virgoletta, nessuno spazio attorno all'uguale (CHIAVE=valore).
# =============================================================================

# --- Identità device — DIVERSO su ogni RPi ---
CAMERA_ID=cam-a                              # cam-a oppure cam-b
DEVICE_NAME=playtrack-campo1-cam-a           # nome leggibile, unico per device
FIELD_ID=campo-1                             # id del campo su Firestore

# --- Firebase — UGUALE su tutti i RPi ---
FIREBASE_PROJECT_ID=playtrack-af614
GOOGLE_APPLICATION_CREDENTIALS=/opt/playtrack/firebase-service-account.json

# --- Percorsi locali — fissi, UGUALI su tutti i RPi ---
RECORDINGS_DIR=/var/playtrack/recordings
QUEUE_DB=/var/playtrack/queue/uploads.db

# --- Telegram — opzionale (comando /foto per verificare l'inquadratura) ---
# Token: DIVERSO per ogni camera (ogni RPi ha il suo bot, da @BotFather).
# Chat id: UGUALE su tutti i RPi (id del gruppo Telegram condiviso).
# Lascia vuoto TELEGRAM_BOT_TOKEN per tenere il bot disattivato.
TELEGRAM_BOT_TOKEN=7891234567:AAFq3xZ_metti-qui-il-token-di-questa-camera
TELEGRAM_CHAT_ID=-1001234567890
